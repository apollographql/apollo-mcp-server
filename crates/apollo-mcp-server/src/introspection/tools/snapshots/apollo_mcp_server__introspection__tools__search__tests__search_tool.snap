---
source: crates/apollo-mcp-server/src/introspection/tools/search.rs
expression: content_to_snapshot(result)
---
enum UserRole {
  ADMIN
  MODERATOR
  USER
  GUEST
}

type User implements Node {
  role: UserRole!
  profile: UserProfile
}

type UserProfile {
  firstName: String
  lastName: String
  bio: String
  avatar: Media
  socialLinks: [SocialLink!]!
  location: Location
}

type Comment implements Node {
  reactions: [Reaction!]!
}

type Reaction {
  user: User!
}

type Query {
  user(id: ID!): User
  comments(postId: ID!): [Comment!]!
}

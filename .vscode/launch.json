{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug apollo-mcp-server [TheSpaceDevs]",
      "cargo": {
        "args": ["build", "--bin=apollo-mcp-server", "--lib"],
        "filter": {
          "name": "apollo-mcp-server",
          "kind": "bin",
        },
      },
      "args": ["examples/TheSpaceDevs/config.yaml"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "APOLLO_MCP_LOGGING__LEVEL": "debug",
      },
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug apollo-mcp-server [Weather]",
      "cargo": {
        "args": ["build", "--bin=apollo-mcp-server", "--lib"],
        "filter": {
          "name": "apollo-mcp-server",
          "kind": "bin",
        },
      },
      "args": ["examples/weather/config.yaml"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "APOLLO_MCP_LOGGING__LEVEL": "debug",
      },
    },
  ],
}
